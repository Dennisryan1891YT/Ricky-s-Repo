<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.netflix" name="Netflix" version="1.0.0" provider-name="Netflix">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="xbmc.addon" version="14.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="__init__.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Netflix - Streaming Entertainment</summary>
        <description>Stream movies, TV shows, and documentaries from Netflix</description>
        <disclaimer>This add-on requires a valid Netflix subscription</disclaimer>
        <language>en</language>
        <platform>all</platform>
        <license>GPL-2.0-only</license>
        <forum></forum>
        <website>https://www.netflix.com</website>
        <email></email>
        <source>https://github.com/Dennisryan1891YT/Ricky-s-Repo</source>
    </extension>
</addon>