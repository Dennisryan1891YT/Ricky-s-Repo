<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.globaltv" name="Global TV" version="1.0.0" provider-name="Global">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="xbmc.addon" version="14.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="__init__.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Global TV - Canadian Broadcasting</summary>
        <description>Stream content from Global TV, Canada's television network</description>
        <disclaimer>This add-on requires a valid Global TV account</disclaimer>
        <language>en</language>
        <platform>all</platform>
        <license>GPL-2.0-only</license>
        <forum></forum>
        <website>https://www.globaltv.com</website>
        <email></email>
        <source>https://github.com/Dennisryan1891YT/Ricky-s-Repo</source>
    </extension>
</addon>